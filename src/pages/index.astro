  <script>
    // ── Consultation form ──────────────────────────────────────────────────
    const ctaForm = document.getElementById('cta-consult-form');
    const ctaBtn = document.getElementById('cta-submit-btn');
    const ctaThankYou = document.getElementById('cta-thank-you');
    const ctaFormWrap = document.getElementById('cta-form-wrap');

    ctaForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      ctaBtn.textContent = 'Submitting…';
      ctaBtn.disabled = true;

      const data = Object.fromEntries(new FormData(ctaForm));
      try {
        await fetch('/api/consultation', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, source: 'homepage-cta' }),
        });
      } catch (_) {}

      ctaFormWrap.classList.add('hidden');
      ctaThankYou.classList.remove('hidden');
    });

    // ── Hero email capture form ────────────────────────────────────────────
    const heroForm = document.getElementById('hero-email-form');
    const heroBtn  = document.getElementById('hero-email-btn');
    const heroMsg  = document.getElementById('hero-email-msg');

    heroForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = new FormData(heroForm).get('email');
      heroBtn.textContent = 'Sending…';
      heroBtn.disabled = true;

      const apiBase = (document.documentElement.dataset.apiBase || '').replace(/\/$/, '');
      try {
        const resp = await fetch(`${apiBase}/api/v1/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'homepage-lead-magnet' }),
        });
        heroMsg.classList.remove('hidden', 'text-red-400');
        if (resp.ok) {
          heroMsg.textContent = '✓ Guide on its way — check your inbox!';
          heroMsg.style.color = '#C9922A';
          heroForm.reset();
        } else {
          heroMsg.textContent = 'Something went wrong. Please try again.';
          heroMsg.classList.add('text-red-400');
        }
      } catch {
        heroMsg.classList.remove('hidden');
        heroMsg.textContent = 'Something went wrong. Please try again.';
        heroMsg.classList.add('text-red-400');
      }

      heroMsg.classList.remove('hidden');
      heroBtn.textContent = 'Send Me the Guide';
      heroBtn.disabled = false;
    });
  </script>

