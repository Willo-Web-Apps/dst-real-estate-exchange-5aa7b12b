---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0)
);

function readTime(body: string | undefined) {
  const words = body?.split(/\s+/).length ?? 0;
  return Math.max(1, Math.ceil(words / 225));
}
---
<Base title="DST & 1031 Exchange Education | Vestara Blog" description="Expert guides on DSTs, 1031 exchanges, and retirement income strategies for retiring real estate investors.">

  <!-- Hero -->
  <div class="bg-brand-500 py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-300 text-sm font-semibold uppercase tracking-widest mb-4">Vestara Education Center</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white font-display mb-4">DST & 1031 Exchange Guides</h1>
      <p class="text-brand-100/80 text-lg max-w-2xl mx-auto">Straight-talk guides to help retiring investors understand Delaware Statutory Trusts, 1031 exchanges, and passive income strategies.</p>
    </div>
  </div>

  <!-- Articles grid -->
  <section class="py-16 bg-surface-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      {posts.length === 0 && (
        <p class="text-surface-800/50 text-center py-12">No posts yet — check back soon.</p>
      )}

      <!-- Featured first post -->
      {posts.length > 0 && (
        <a href={`/blog/${posts[0].id}`} class="group block bg-white rounded-2xl shadow-sm border border-surface-200 hover:shadow-md transition-shadow mb-8 overflow-hidden">
          <div class="bg-brand-500 px-8 py-6">
            <span class="inline-block bg-accent-400 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3">Featured</span>
            <h2 class="text-2xl md:text-3xl font-bold text-white font-display leading-snug group-hover:text-accent-300 transition-colors">
              {posts[0].data.title}
            </h2>
          </div>
          <div class="px-8 py-6">
            {posts[0].data.description && (
              <p class="text-surface-800/70 text-lg leading-relaxed mb-4">{posts[0].data.description}</p>
            )}
            <div class="flex items-center gap-4 text-sm text-surface-800/40">
              {posts[0].data.pubDate && (
                <time>{posts[0].data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              )}
              <span>·</span>
              <span>{readTime(posts[0].body)} min read</span>
              <span class="ml-auto text-accent-500 font-semibold group-hover:text-brand-500 transition-colors">Read article →</span>
            </div>
          </div>
        </a>
      )}

      <!-- Remaining posts grid -->
      {posts.length > 1 && (
        <div class="grid md:grid-cols-2 gap-6">
          {posts.slice(1).map((post) => (
            <a href={`/blog/${post.id}`} class="group block bg-white rounded-2xl shadow-sm border border-surface-200 hover:shadow-md transition-shadow overflow-hidden">
              <div class="p-6">
                <h2 class="text-lg font-bold text-surface-900 font-display leading-snug mb-3 group-hover:text-brand-500 transition-colors">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-surface-800/60 text-sm leading-relaxed mb-4 line-clamp-3">{post.data.description}</p>
                )}
                <div class="flex items-center gap-3 text-xs text-surface-800/40 pt-3 border-t border-surface-100">
                  {post.data.pubDate && (
                    <time>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                  )}
                  <span>·</span>
                  <span>{readTime(post.body)} min read</span>
                  <span class="ml-auto text-accent-500 font-semibold text-xs group-hover:text-brand-500 transition-colors">Read →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <!-- CTA -->
      <div class="mt-14 bg-brand-500 rounded-2xl p-8 text-center">
        <p class="text-accent-300 text-sm font-semibold uppercase tracking-widest mb-2">Ready to Talk?</p>
        <h3 class="text-white font-display text-2xl font-bold mb-3">Get a Free DST Strategy Session</h3>
        <p class="text-brand-100/70 mb-6 max-w-md mx-auto">Tell us about your property and we'll help you map out your 1031 exchange options.</p>
        <a href="/#consultation" class="inline-block bg-accent-400 hover:bg-accent-500 text-white font-bold px-7 py-3 rounded-xl transition-colors">
          Schedule Free Consultation →
        </a>
      </div>

    </div>
  </section>

</Base>
