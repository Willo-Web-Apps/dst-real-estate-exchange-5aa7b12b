---
import Base from '../../layouts/Base.astro';
---
<Base title="Purchase Successful — Vestara">
  <section class="relative py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(160deg, oklch(0.20 0.020 243) 0%, oklch(0.25 0.09 243) 55%, oklch(0.31 0.10 243) 100%);"></div>
    <div class="relative max-w-lg mx-auto px-4 sm:px-6 text-center">

      <!-- Success Icon -->
      <div class="mx-auto w-20 h-20 rounded-full flex items-center justify-center mb-8" style="background: rgba(201,146,42,0.15); border: 2px solid #C9922A;">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#C9922A">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold text-white font-display mb-4">You're In!</h1>
      <p class="text-lg text-white/70 leading-relaxed mb-10">
        Your purchase is confirmed. Your complete DST 1031 Guide is ready to read right now — no download needed.
      </p>

      <!-- Primary CTA -->
      <a
        href="/guide"
        class="inline-flex items-center gap-3 px-8 py-4 font-bold text-white rounded-xl transition-all hover:scale-105 hover:shadow-lg mb-6"
        style="background:#C9922A;"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
        Read Your Guide Now
      </a>

      <p class="text-white/40 text-sm">Bookmark the guide page — you can return to it anytime.</p>

      <div class="mt-12 pt-8 border-t border-white/10">
        <a href="/" class="text-white/40 hover:text-white/60 text-sm transition-colors">← Back to Vestara</a>
      </div>

    </div>
  </section>
</Base>
