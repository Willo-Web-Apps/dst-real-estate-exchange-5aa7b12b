---
---
<header class="sticky top-0 z-50 border-b backdrop-blur-lg"
        style="background: oklch(0.985 0.006 80 / 0.92); border-color: oklch(0.92 0.012 76);">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Vestara home">
      <!-- Small gold mark -->
      <span class="w-1.5 h-6 rounded-sm" style="background: #C9922A;"></span>
      <span class="text-xl font-bold tracking-tight font-display" style="color: oklch(0.20 0.020 243);">
        Vestara
      </span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="/#guide"
         class="text-sm font-medium transition-colors duration-150 hover:opacity-100"
         style="color: oklch(0.28 0.020 240 / 0.60);">
        DST Guide
      </a>
      <a href="/#how-it-works"
         class="text-sm font-medium transition-colors duration-150 hover:opacity-100"
         style="color: oklch(0.28 0.020 240 / 0.60);">
        How It Works
      </a>
      <a href="/pricing"
         class="text-sm font-medium transition-colors duration-150 hover:opacity-100"
         style="color: oklch(0.28 0.020 240 / 0.60);">
        Pricing
      </a>
    </div>

    <!-- CTA -->
    <a
      href="/#cta"
      class="text-sm font-semibold px-5 py-2 rounded-lg transition-colors duration-150"
      style="background: oklch(0.31 0.10 243); color: #fff;"
    >
      Get the free guide
    </a>
  </nav>
</header>
